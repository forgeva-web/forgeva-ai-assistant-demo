{
  "semi": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 80,
  "proseWrap": "preserve",
  "useTabs": false,
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "bracketSameLine": false,
  "arrowParens": "always",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react$",
    "^next",
    "<THIRD_PARTY_MODULES>",
    "^@/components/(.*)$",
    "^@utils/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true
}
