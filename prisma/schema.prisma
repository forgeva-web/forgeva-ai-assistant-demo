generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DemoVisitor {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  firstName   String
  lastName    String
  tokensUsed  Int      @default(0)
  tokenBudget Int      @default(50000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Site {
  id           String        @id @default(cuid())
  name         String
  url          String        @unique
  slug         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]
  indexedPages IndexedPage[]
  siteConfig   SiteConfig[]
}

model IndexedPage {
  id              String         @id @default(cuid())
  siteId          String
  url             String
  title           String?
  metaTitle       String?
  metaDescription String?
  contentHash     String
  wordCount       Int            @default(0)
  h1Count         Int            @default(0)
  missingAltCount Int            @default(0)
  indexStatus     IndexStatus    @default(PENDING)
  lastIndexedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  aisoScore       AisoScore?
  chunks          ContentChunk[]
  site            Site           @relation(fields: [siteId], references: [id])
  proposedEdits   ProposedEdit[]
  pageContent     PageContent[]

  @@unique([siteId, url])
}

model ContentChunk {
  id            String                 @id @default(cuid())
  indexedPageId String
  chunkIndex    Int
  content       String
  contentType   ChunkType
  embedding     Unsupported("vector")?
  createdAt     DateTime               @default(now())
  indexedPage   IndexedPage            @relation(fields: [indexedPageId], references: [id])
}

model ChatSession {
  id        String   @id @default(cuid())
  siteId    String
  messages  Json[]   @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  site      Site     @relation(fields: [siteId], references: [id])
}

model ProposedEdit {
  id            String      @id @default(cuid())
  indexedPageId String
  fieldName     EditField
  originalValue String
  proposedValue String
  status        EditStatus  @default(PENDING)
  appliedAt     DateTime?
  createdAt     DateTime    @default(now())
  indexedPage   IndexedPage @relation(fields: [indexedPageId], references: [id])
}

model AisoScore {
  id          String      @id @default(cuid())
  pageId      String      @unique
  totalScore  Int
  scores      Json
  actionItems Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  page        IndexedPage @relation(fields: [pageId], references: [id])
}

model PageContent {
  id            String      @id @default(cuid())
  indexedPageId String
  key           String
  value         String
  contentType   String      @default("TEXT")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  indexedPage   IndexedPage @relation(fields: [indexedPageId], references: [id], onDelete: Cascade)

  @@unique([indexedPageId, key])
}

model SiteConfig {
  id        String   @id @default(cuid())
  siteId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, key])
}

enum IndexStatus {
  PENDING
  INDEXING
  COMPLETE
  ERROR
}

enum ChunkType {
  HEADING
  PARAGRAPH
  META
  ALT_TEXT
}

enum EditField {
  META_TITLE
  META_DESCRIPTION
  BODY_COPY
}

enum EditStatus {
  PENDING
  ACCEPTED
  REJECTED
}
